{
	"name": "gravityjs-animations",
  "version": "1.0.0",
  "description": "A UI animation and styling framework for making animations behave like real life objects in Earth's gravity",
  "main": "dist/gravityjs.cjs",
  "module": "dist/gravityjs.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/gravityjs.esm.js",
      "require": "./dist/gravityjs.cjs"
    },
    "./dist/gravityjs.css": "./dist/gravityjs.css"
  },
  "scripts": {
    "build": "tsc && npm run build:umd && npm run build:esm && npm run build:cjs && npm run build:css",
    "build:umd": "esbuild src/index.ts --bundle --format=iife --outfile=dist/gravityjs.umd.js --global-name=GravityJS",
    "build:esm": "esbuild src/index.ts --bundle --format=esm --outfile=dist/gravityjs.esm.js",
    "build:cjs": "esbuild src/index.ts --bundle --format=cjs --outfile=dist/gravityjs.cjs",
    "build:css": "node -e \"require('fs').copyFileSync('src/gravity.css','dist/gravityjs.css')\"",
    "dev": "tsc --watch",
    "demo": "npx serve .",
	    "lint": "eslint src tests --ext .ts",
	    "format": "eslint src tests --ext .ts --fix",
	    "format:check": "npm run lint",
    "test": "npm run build && vitest run && npm run test:types",
    "test:types": "tsc --project tsconfig.types.json --noEmit"
  },
  "keywords": [
    "gravity",
    "physics",
    "animation",
    "ui",
    "animation-library"
  ],
  "author": "Andrzej Skowron",
  "contributors": [
    {
      "name": "Andrzej Skowron"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
		"url": "https://github.com/andrzejskowron/GravityJS-Animations.git"
  },
	"homepage": "https://github.com/andrzejskowron/GravityJS-Animations",
  "bugs": {
		"url": "https://github.com/andrzejskowron/GravityJS-Animations/issues"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.3",
    "jsdom": "^28.1.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
